#. :src: bpy.types.CloudRigPreferences.advanced_mode
msgid "Advanced Mode"
msgstr "高级模式"

#. :src: bpy.types.CloudRigPreferences.advanced_mode
msgid "Reveal advanced options in the Generator and Rig Component interfaces"
msgstr "在生成器和骨架组件界面中显示高级选项"

#. :src: bpy.types.CloudRigPreferences.bone_set_show_advanced
msgid "Show Internal Bone Sets"
msgstr "显示内部骨骼集"

#. :src: bpy.types.CloudRigPreferences.bone_set_show_advanced
msgid "Reveal bone sets that are marked as internal, ie. mechanism bones. You would customize these much less frequently than the controls, which are exposed to animators"
msgstr "显示标记为内部的骨骼集,例如机制骨骼.与向动画师公开的控制骨骼相比,您自定义这些骨骼的频率要低得多"

#. :src: bpy.types.CloudRigPreferences.component_overview_mode
msgid "Overview Mode"
msgstr "概览模式"

#. :src: bpy.types.CloudRigPreferences.component_overview_mode
msgid "Parameter view mode"
msgstr "参数查看模式"

#. :src: bpy.types.CloudRigPreferences.component_overview_mode:'ACTIVE'
msgid "Show the 3D Viewport active bone's component & parameters"
msgstr "显示3D视图中活动骨骼所属组件的参数"

#. :src: bpy.types.CloudRigPreferences.component_overview_mode:'LIST'
msgid "Show a list of all components on this rig, so you don't have to select bones in the 3D View"
msgstr "显示此骨架上的所有组件列表,因此您无需在3D视图中选择骨骼"

#. :src: bpy.types.CloudRigPreferences.overlay_dash_length
msgid "Length of the dashed lines in the rig preview overlay."
msgstr "骨架预览叠加层中虚线的长度."

#. :src: bpy.types.CloudRigPreferences.overlay_mode
msgid "Choose which components should have rig preview rendered. More components has a greater impact on performance when transforming metarig bones"
msgstr "选择应为哪些组件渲染骨架预览.变换元骨架骨骼时,组件越多对性能影响越大."

#. :src: bpy.types.CloudRigPreferences.overlay_mode:'NONE'
msgid "No rig preview. No performance cost"
msgstr "无骨架预览.无性能开销"

#. :src: bpy.types.CloudRigPreferences.overlay_mode:'ACTIVE'
msgid "Preview active bone's component. Minimal performance impact"
msgstr "预览活动骨骼的组件.对性能影响极小"

#. :src: bpy.types.CloudRigPreferences.overlay_mode:'SELECTED'
msgid "Preview components of selected bones. Performance impact depends on selection"
msgstr "预览所选骨骼的组件.性能影响取决于选择情况"

#. :src: bpy.types.CloudRigPreferences.overlay_mode:'CHILDREN'
msgid "Selected & Children"
msgstr "所选及其子级"

#. :src: bpy.types.CloudRigPreferences.overlay_mode:'CHILDREN'
msgid "Preview components of selected bones & their children. Performance impact may be noticable"
msgstr "预览所选骨骼及其子级的组件.可能会产生明显的性能影响"

#. :src: bpy.types.CloudRigPreferences.overlay_mode:'VISIBLE'
msgid "Preview all visible bones' components. Noticable performance impact while transforming metarig bones"
msgstr "预览所有可见骨骼的组件.变换元骨架骨骼时会产生明显的性能影响"

#. :src: bpy.types.CloudRigPreferences.overlay_opacity
msgid "Opacity of the rig preview overlay."
msgstr "骨架预览叠加层的不透明度"

#. :src: bpy.types.CloudRigPreferences.overlay_use_dashed
msgid "Dashed"
msgstr "虚线"

#. :src: bpy.types.CloudRigPreferences.overlay_use_dashed
msgid "Use dashed lines for the rig preview. Slight performance impact"
msgstr "为骨架预览使用虚线.对性能略有影响"

#. :src: bpy.types.CloudRigPreferences.ui_mode
msgid "Interface Location"
msgstr "界面位置"

#. :src: bpy.types.CloudRigPreferences.ui_mode:'PROPERTIES'
msgid "Properties Editor"
msgstr "属性编辑器"

#. :src: bpy.types.CloudRigPreferences.ui_mode:'PROPERTIES'
msgid "Only display CloudRig's UI in the Properties Editor"
msgstr "仅在属性编辑器中显示CloudRig的界面"

#. :src: bpy.types.CloudRigPreferences.ui_mode:'HEADER'
msgid "3D View Header"
msgstr "3D视图标题栏"

#. :src: bpy.types.CloudRigPreferences.ui_mode:'HEADER'
msgid "Display CloudRig's UI in the 3D View's header, next to the Shading pop-over"
msgstr "在3D视图的标题栏中显示CloudRig的界面,位于着色弹出框旁边"

#. :src: bpy.types.CloudRigPreferences.ui_mode:'BOTH'
msgid "Display CloudRig's UI in both places"
msgstr "在两处同时显示CloudRig的界面"

#. :src: bpy.types.CloudRigPreferences.widget_import_method
msgid "Custom Shape Import Method"
msgstr "自定义形状导入方式"

#. :src: bpy.types.CloudRigPreferences.widget_import_method
msgid "Whether custom shapes should be linked or appended"
msgstr "自定义形状应该链接还是追加"

#. :src: bpy.types.CloudRigPreferences.widget_library
msgid "Custom Shape Library"
msgstr "自定义形状库"

#. :src: bpy.types.CloudRigPreferences.widget_library
msgid "Path to your custom shapes library .blend file. Objects within this .blend file whose names start with 'WGT-' will appear in CloudRig's various widget selection interfaces"
msgstr "指向自定义形状库 .blend 文件的路径.此 .blend 文件中名称以 'WGT-' 开头的对象将出现在CloudRig的各种控件选择界面中"

